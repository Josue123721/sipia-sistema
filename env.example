# ============================================================
# SIPIA --- variables de entorno
# ============================================================
# 1. Copia este archivo como .env:      cp .env.example .env
# 2. Completa los valores abajo.
# 3. NUNCA subas el archivo .env real a git (agregalo a .gitignore).
#    Este archivo .env.example si se sube, pero siempre sin valores reales.

# --- Bot de Telegram (obligatorio si usas alertas por Telegram) --------
# Token del bot, obtenido hablando con @BotFather en Telegram.
# Formato: 123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SIPIA_TELEGRAM_TOKEN=

# Chat ID del operador (o grupo) que recibira las alertas.
# Puedes obtenerlo hablando con @userinfobot en Telegram.
# Si es un grupo, el ID suele ser negativo (ej. -1001234567890).
SIPIA_TELEGRAM_CHAT_ID=

# --- API / servidor (opcional, valores por defecto entre parentesis) ----
# Host y puerto donde corre la API que consume el dashboard.
# Deben coincidir con la URL configurada en el dashboard HTML (API_BASE).
SIPIA_API_HOST=127.0.0.1
SIPIA_API_PORT=8000

# Origenes permitidos para CORS, separados por coma. Util si el dashboard
# se sirve desde un dominio/puerto distinto al de la API.
# Ejemplo: http://localhost:5173,https://dashboard.miempresa.com
SIPIA_CORS_ORIGINS=http://127.0.0.1:8000

# --- Base de datos y reportes --------------------------------------------
# Ruta al archivo SQLite. Si se deja vacio, se usa sipia_readings.db
# junto al script (ver BASE_DIR en generar_reporte.py).
SIPIA_DB_PATH=

# Carpeta donde se guardan los PDF generados por generar_reporte.py.
SIPIA_REPORTES_DIR=./reportes

# --- Sensores fisicos (opcional, solo si usas hardware real via pyserial) -
# Puerto serial donde estan conectados los sensores.
# Windows: COM3, COM4, etc. Linux: /dev/ttyUSB0, /dev/ttyACM0, etc.
SIPIA_SERIAL_PORT=
SIPIA_SERIAL_BAUDRATE=9600

# --- Alertas de audio -----------------------------------------------------
# Volumen inicial de las alertas sonoras (0-100), coincide con el slider
# por defecto del dashboard.
SIPIA_ALERTA_VOLUMEN=80

# --- Logging ---------------------------------------------------------------
# Nivel de log: DEBUG, INFO, WARNING, ERROR
SIPIA_LOG_LEVEL=INFO
